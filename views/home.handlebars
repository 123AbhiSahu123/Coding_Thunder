{{!-- section-1 --}}
<div id="carouselExampleFade" class="carousel slide carousel-fade ">
  <div class="carousel-inner">
    <div class="carousel-item active h-50">
      <img src="/image/A.jpg" class="d-block w-100 img-fluid" alt="not found"
        style="height: 500px; object-fit: cover;" />
    </div>
    <div class="carousel-item">
      <img src="/image/B.jpg" class="d-block w-100 img-fluid" alt="not found"
        style="height: 500px; object-fit: cover;" />
    </div>
    <div class="carousel-item">
      <img src="/image/C.jpg" class="d-block w-100 img-fluid" alt="not found"
        style="height: 500px; object-fit: cover;" />
    </div>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleFade" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleFade" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

{{!-- section-2 --}}

<div class="container-fluid mt-5 mb-5">
  <div class="row">
    <div class="col-lg-12">
      <div class="section-title text-center">
        <h3 class="text-white fw-bold bg-primary py-3">{{title}}</h3>
        <p class="fs-3 fw-light mb-5">The core philosophy of Coding Thunder is "Learning by Doing."</p>
      </div>
    </div>
  </div>

  <div class="row">
    {{#each funFacts}}
    <div class="counterup_style--1 col-lg-4 col-md-4 col-sm-6 col-12 text-center">
      <h5 class="counter">
        <span>{{this.count}}</span>
      </h5>
      <p class="description">{{this.description}}</p>
    </div>
    {{/each}}
  </div>
</div>


{{!-- section-3 --}}
<div class="container-fluid">
  <div class="section-title text-center">
    <h3 class="text-white bg-primary py-3 fw-bold mb-5">We provided Courses</h3>
  </div>
  <div class="row g-4 mt-5 mb-5">
    {{#each courses}}
    <div class="colm col-12 col-md-6 col-lg-4">
      <div class="card mb-3 w-100">
        <div class="card-body">
          <h4 class="card-title">{{this.title}}</h4>
          <p class="card-text">{{this.desc}}</p>
          <h6>
            <span class="text-muted text-decoration-line-through">Real Price:- ₹{{this.oldPrice}}</span>
          </h6>
          <div class="d-flex justify-content-between align-items-center">
            <a href="/checkout/{{this.id}}?price={{this.price}}" class="btn btn-primary">Buy Now</a>
            <span class="fw-bold text-success">Offer Price:- ₹{{this.price}}</span>
          </div>
        </div>
      </div>
    </div>
    {{/each}}
  </div>
</div>