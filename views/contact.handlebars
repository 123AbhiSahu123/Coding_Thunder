<div class="container d-flex justify-content-center align-items-center min-vh-100 mt-3 mb-3">
    <div class="card shadow-lg border-0 rounded-4" style="width: 100%;">

        <!-- Header -->
        <div class="card-header bg-primary text-white text-center rounded-top-4 py-3">
            <h4 class="mb-0">Reach Us ✨</h4>
            <small>Join us and start your journey</small>
        </div>

        <!-- Body -->
        <div class="card-body p-4">
            <form action="/contact/send-contact" method="POST">

                <!-- Name -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Full Name:</label>
                    <input type="text" class="form-control rounded-pill px-3" name="name" placeholder="Enter your name"
                        required>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email Address:</label>
                    <input type="email" class="form-control rounded-pill px-3" name="email"
                        placeholder="Enter your email" required>
                    <div class="form-text">We’ll never share your email.</div>
                </div>

                <!-- Phone -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Phone Number:</label>
                    <input type="tel" class="form-control rounded-pill px-3" name="phone"
                        placeholder="Enter your phone number" required>
                </div>


                <!-- Subject -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Subject:</label>
                    <input type="text" class="form-control rounded-pill px-3" name="subject" placeholder="Subject"
                        required>
                </div>

                <!-- Message -->
                <div class="mb-3">
                    <label for="validationTextarea" class="form-label fw-semibold">Message:</label>
                    <textarea class="form-control" id="validationTextarea" name="message"
                        placeholder="Drop your message here..." required></textarea>
                    <div class="invalid-feedback">
                        Please enter a message in the textarea.
                    </div>
                </div>

                <!-- Submit -->
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill py-2">
                        Send Message
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>

{{#if alertMessage}}
<script>
    // Ye tabhi chalega jab server se alertMessage aayega
    alert("{{alertMessage}}");

    // Alert ke baad agar aap URL ko clean karna chahte hain (Optional)
    window.history.replaceState({}, document.title, "/contact");
</script>
{{/if}}